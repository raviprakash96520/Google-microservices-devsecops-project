pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_NAME  = 'harishnshetty/recommendationservice' // Deeni mee DockerHub username ki marchukondi block avvakunda
        IMAGE_NAME   = 'recommendationservice'
        PATH         = "$PATH:/var/lib/jenkins/.local/bin"   // Pip binaries path
    }

    stages {
        // 1. Workspace Cleanup
        stage("Clean Workspace") {
            steps { cleanWs() }
        }

        // 2. Git Checkout (Updated with your new repository)
        stage("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/raviprakash96520/Google-microservices-devsecops-project.git'
            }
        }

        // 3. Secret Scan (Gitleaks)
        stage("Gitleaks Secret Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh 'gitleaks detect --source=. -v || true'
                }
            }
        }

        // 4. License Scan (Trivy License)
        stage("License Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh 'trivy fs . --scanners license --severity HIGH,CRITICAL > trivy-license-report.txt || true'
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/trivy-license-report.txt' }
            }
        }

        // 5. SAST: Bandit (Python Specific)
        stage("Bandit Security Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    python3 -m pip install --user --upgrade bandit
                    bandit -r . -f json -o bandit-report.json || true
                    '''
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/bandit-report.json' }
            }
        }

        // 6. SAST & Code Quality: SonarQube
        stage("SonarQube Analysis") {
            steps {
                dir('src/recommendationservice') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                          -Dsonar.projectKey=recommendationservice \
                          -Dsonar.projectName=recommendationservice \
                          -Dsonar.sources=. \
                          -Dsonar.language=py
                        '''
                    }
                }
            }
        }

        // 7. Quality Gate
        stage("Quality Gate") {
            steps {
                script {
                    timeout(time: 3, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true, credentialsId: 'sonar-token'
                    }
                }
            }
        }

        // 8. Install Dependencies
        stage("Install Dependencies") {
            steps {
                dir('src/recommendationservice') {
                    sh 'python3 -m pip install --user -r requirements.txt || true'
                }
            }
        }

        // 9. Unit Test & Code Coverage
        stage("Unit Test & Code Coverage") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    python3 -m pip install --user pytest pytest-cov
                    python3 -m pytest --cov=. --cov-report=xml || true
                    '''
                }
            }
        }

        // 10. SCA: Safety Dependency Scan
        stage("Safety Dependency Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    python3 -m pip install --user safety
                    safety check --full-report --output json > safety-report.json || true
                    '''
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/safety-report.json' }
            }
        }

        // 11. IaC Scan (Checkov)
        stage("Checkov IaC Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    python3 -m pip install --user checkov
                    checkov -d . --output json > checkov-report.json || true
                    '''
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/checkov-report.json' }
            }
        }

        // 12. Trivy File System Scan
        stage("Trivy File Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh 'trivy fs . --severity CRITICAL,HIGH --exit-code 1 --scanners vuln,misconfig,secret > trivy-fs-report.txt || true'
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/trivy-fs-report.txt' }
            }
        }

        // 13. Docker Build
        stage("Build Docker Image") {
            steps {
                dir('src/recommendationservice') {
                    script {
                        env.IMAGE_TAG = "$DOCKER_NAME:${BUILD_NUMBER}"
                        sh "docker rmi -f $IMAGE_NAME ${env.IMAGE_TAG} || true"
                        sh "docker build -t $IMAGE_NAME ."
                        sh "docker tag $IMAGE_NAME ${env.IMAGE_TAG}"
                    }
                }
            }
        }

        // 14. Container Image Scan (Trivy Image)
        stage("Trivy Scan Image") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    trivy image -f json -o trivy-image-email.json ${IMAGE_TAG}
                    trivy image -f table -o trivy-image-email.txt ${IMAGE_TAG}
                    '''
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/trivy-image-email.*' }
            }
        }

        // 15. SBOM Generation
        stage("SBOM Generation") {
            steps {
                dir('src/recommendationservice') {
                    sh "trivy image --format cyclonedx --output sbom.json ${IMAGE_TAG} || true"
                }
            }
            post {
                always { archiveArtifacts 'src/recommendationservice/sbom.json' }
            }
        }

        // 16. Push Registry & Image Signing
        stage("Push & Sign Image") {
            steps {
                dir('src/recommendationservice') {
                    withCredentials([string(credentialsId: 'docker-cred', variable: 'dockerpwd')]) {
                        sh '''
                        docker login -u harishnshetty -p ${dockerpwd}
                        docker push ${IMAGE_TAG}
                        docker tag ${IMAGE_NAME} ${DOCKER_NAME}:latest
                        docker push ${DOCKER_NAME}:latest
                        '''
                    }
                    sh "cosign sign --key env://COSIGN_PRIVATE_KEY ${IMAGE_TAG} --allow-insecure-registry || true"
                }
            }
        }
    }

    // --- Final Notifications ---
    post {
        always {
            dir('src/recommendationservice') {
                script {
                    def buildStatus = currentBuild.currentResult
                    def buildUser = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')[0]?.userId ?: ' Jenkins User'

                    emailext (
                        subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
                            <p>recommendationservice Google-Shop DevSecOps pipeline status.</p>
                            <p>Project: ${env.JOB_NAME}</p>
                            <p>Build Number: ${env.BUILD_NUMBER}</p>
                            <p>Build Status: ${buildStatus}</p>
                            <p>Started by: ${buildUser}</p>
                            <p>Build URL: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                        """,
                        to: 'harishn662@gmail.com', // Deeni mee personal email mapped target ki marchukogalaru
                        from: 'harishn662@gmail.com',
                        mimeType: 'text/html',
                        attachmentsPattern: 'bandit-report.json,safety-report.json,checkov-report.json,trivy-fs-report.txt,trivy-license-report.txt,trivy-image-email.json,trivy-image-email.txt,sbom.json'
                    )
                }
            }
        }
    }
}