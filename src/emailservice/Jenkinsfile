pipeline {
    agent any

    tools {
        jdk 'jdk19'
    }

    environment {
        SCANNER_HOME    = tool 'sonar-scanner'
        DOCKER_NAME     = 'ravi6198/emailservice'
        IMAGE_NAME      = 'emailservice'
        IMAGE_TAG       = "${BUILD_NUMBER}"
        SERVICE_DIR     = 'src/emailservice'
        SONAR_TOKEN_ID  = 'sonar-token'
        DOCKER_CREDS_ID = 'docker-cred'
        COSIGN_KEY_ID   = 'cosign-private-key'
    }

    stages {
        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git branch: 'main',
                    url: 'https://github.com/raviprakash96520/Google-microservices-devsecops-project.git'
            }
        }

        stage("Secret Scan (GitLeaks)") {
            steps {
                sh """
                gitleaks detect \
                --source=${SERVICE_DIR} \
                --verbose || true
                """
            }
        }

        stage("License Scan") {
            steps {
                dir("${SERVICE_DIR}") {
                    echo "License validation skipped"
                }
            }
        }

        stage("Bandit Security Scan") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install bandit
                    bandit -r . -f json -o bandit-report.json || true
                    ls -l bandit-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/bandit-report.json",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=emailservice \
                        -Dsonar.projectName=emailservice \
                        -Dsonar.sources=. \
                        -Dsonar.language=py
                        '''
                    }
                }
            }
        }

        stage("Quality Gate") {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate(
                        abortPipeline: true,
                        credentialsId: "${SONAR_TOKEN_ID}"
                    )
                }
            }
        }

        stage("Install Dependencies") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt || true
                    '''
                }
            }
        }

        stage("Safety Dependency Scan") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                    . venv/bin/activate
                    pip install safety
                    safety check --full-report --output json > safety-report.json || true
                    ls -l safety-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/safety-report.json",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("IaC Configuration Scan") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                    trivy config . --severity HIGH,CRITICAL -o iac-report.txt || true
                    ls -l iac-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/iac-report.txt",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("Trivy File Scan") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                    trivy fs . \
                    --severity CRITICAL,HIGH \
                    --scanners vuln,misconfig,secret \
                    --exit-code 1 \
                    -o trivy-fs-report.txt || true
                    ls -l trivy-fs-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/trivy-fs-report.txt",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        env.FINAL_TAG = "${DOCKER_NAME}:${IMAGE_TAG}"
                        sh """
                        docker build -t ${env.FINAL_TAG} .
                        docker images | grep ${IMAGE_NAME}
                        """
                    }
                }
            }
        }

        stage("Generate SBOM Manifest") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh """
                    trivy image --format cyclonedx --output sbom.json ${FINAL_TAG}
                    """
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/sbom.json",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("Trivy Scan Image") {
            steps {
                dir("${SERVICE_DIR}") {
                    sh """
                    trivy image -f json -o trivy-image-email.json ${FINAL_TAG}
                    trivy image -f table -o trivy-image-email.txt ${FINAL_TAG}
                    """
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/trivy-image-email.json",
                        allowEmptyArchive: true
                    )
                    archiveArtifacts(
                        artifacts: "${SERVICE_DIR}/trivy-image-email.txt",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage("Push to DockerHub") {
            steps {
                dir("${SERVICE_DIR}") {
                    withCredentials([
                        usernamePassword(
                            credentialsId: "${DOCKER_CREDS_ID}",
                            usernameVariable: 'DOCKER_USER',
                            passwordVariable: 'DOCKER_PASSWORD'
                        )
                    ]) {
                        // `${FINAL_TAG}` వేరియబుల్ పని చేయాలంటే ఇక్కడ డబుల్ కోట్స్ (""") ఉండాలి
                        sh """
                        echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USER --password-stdin
                        docker push ${FINAL_TAG}
                        """
                    }
                }
            }
        }

        stage("Sign Container Image") {
            steps {
                echo "Cosign signing skipped"
            }
        }
    }

    post {
        always {
            script {
                def buildStatus = currentBuild.currentResult
                emailext(
                    subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: """
                    <p>Emailservice DevSecOps Pipeline Report</p>
                    <p>Build Number: ${env.BUILD_NUMBER}</p>
                    <p>Status: ${buildStatus}</p>
                    <p>Image: ${DOCKER_NAME}:${IMAGE_TAG}</p>
                    <p>Build URL: ${env.BUILD_URL}</p>
                    """,
                    to: "ravireddy6198@gmail.com",
                    from: "ravireddy6198@gmail.com",
                    mimeType: "text/html",
                    attachmentsPattern: "**/bandit-report.json,**/safety-report.json,**/trivy-fs-report.txt,**/iac-report.txt,**/trivy-image-email.json,**/trivy-image-email.txt,**/sbom.json"
                )
            }
            cleanWs()
        }
    }
}