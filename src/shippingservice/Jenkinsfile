pipeline {
    agent any

    tools {
        go 'go1.25'
        jdk 'jdk17'
    }

    environment {
        SCANNER_HOME    = tool 'sonar-scanner'
        DOCKER_NAME     = 'ravi6198/shippingservice'
        IMAGE_NAME      = 'shippingservice'
        SERVICE_DIR     = 'src/shippingservice'
        SONAR_TOKEN_ID  = 'sonar-token'
        DOCKER_CREDS_ID = 'docker-cred'
    }

    stages {
        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/raviprakash96520/Google-microservices-devsecops-project.git'
            }
        }

        stage("Gitleaks Secret Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    echo "Running Gitleaks scan..."
                    gitleaks detect --source=. -v || true
                    '''
                }
            }
        }

        stage("License Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    trivy fs . --scanners license --severity HIGH,CRITICAL > trivy-license-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-license-report.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Go Security Scan (gosec)") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    export PATH=$PATH:$(go env GOPATH)/bin
                    if ! command -v gosec >/dev/null; then
                        echo "Installing gosec..."
                        go install github.com/securego/gosec/v2/cmd/gosec@latest
                    fi
                    gosec -fmt=sonarqube -out gosec-report.json -no-fail ./...
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/gosec-report.json", allowEmptyArchive: true
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                          -Dsonar.projectName=shippingservice \
                          -Dsonar.projectKey=shippingservice \
                          -Dsonar.sources=. \
                          -Dsonar.language=go \
                          -Dsonar.go.gosec.reportPaths=gosec-report.json
                        '''
                    }
                }
            }
        }

        stage("Quality Gate") {
            steps {
                script {
                    timeout(time: 3, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true, credentialsId: "${SONAR_TOKEN_ID}"
                    }
                }
            }
        }

        stage("Go Unit Tests") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh 'go test -v -coverprofile=coverage.out ./... || true'
                }
            }
        }

        stage("Go Build") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    echo "Building shippingservice"
                    CGO_ENABLED=0 go build -o app .
                    '''
                }
            }
        }

        stage("Go Dependency Check") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    export PATH=$PATH:$(go env GOPATH)/bin
                    if ! command -v govulncheck >/dev/null; then
                       go install golang.org/x/vuln/cmd/govulncheck@latest
                    fi
                    govulncheck ./... > govulncheck-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/govulncheck-report.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Checkov IaC Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    python3 -m pip install --user checkov --break-system-packages || true
                    checkov -d . --output json > checkov-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/checkov-report.json", allowEmptyArchive: true
                }
            }
        }

        stage("Trivy File Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    trivy fs . --severity CRITICAL,HIGH --exit-code 1 --scanners vuln,misconfig,secret > trivy-fs-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-fs-report.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    script {
                        env.IMAGE_TAG = "${DOCKER_NAME}:${BUILD_NUMBER}"
                        sh """
                        echo "Current Directory: \$(pwd)"
                        echo "Dockerfile first lines:"
                        head -5 Dockerfile

                        docker rmi -f ${IMAGE_NAME} ${env.IMAGE_TAG} || true
                        docker build -t ${IMAGE_NAME} .
                        docker tag ${IMAGE_NAME} ${env.IMAGE_TAG}
                        """
                    }
                }
            }
        }

        stage("Generate SBOM Manifest") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh 'trivy image --format cyclonedx --output sbom.json ${IMAGE_TAG}'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/sbom.json", allowEmptyArchive: true
                }
            }
        }

        stage("Trivy Scan Image") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh """
                    trivy image -f json -o trivy-image-shippingservice.json ${env.IMAGE_TAG}
                    trivy image -f table -o trivy-image-shippingservice.txt ${env.IMAGE_TAG}
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-image-shippingservice.json", allowEmptyArchive: true
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-image-shippingservice.txt", allowEmptyArchive: true
                }
            }
        }

      stage("Push Image To DockerHub") {

    steps {

        dir("${SERVICE_DIR}") {

            withCredentials([
                string(
                    credentialsId: 'docker-cred',
                    variable: 'dockerpwd'
                )
            ]) {

                sh '''
                
                docker login -u ravi6198 -p ${dockerpwd}

                docker push ${IMAGE_TAG}

                docker tag ${IMAGE_NAME} ${DOCKER_NAME}:latest

                docker push ${DOCKER_NAME}:latest

                '''

            }

        }

    }

}

        stage("Cosign Image Signing") {
            steps {
                echo "Cosign signing skipped"
            }
        }
    }

    post {
        always {
            dir("${env.SERVICE_DIR}") {
                script {
                    def buildStatus = currentBuild.currentResult
                    def buildUser = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')[0]?.userId ?: 'Jenkins User'

                    emailext (
                        subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
                            <p>Shippingservice Google-Shop DevSecOps Pipeline Report</p>
                            <p>Project: ${env.JOB_NAME}</p>
                            <p>Build Number: ${env.BUILD_NUMBER}</p>
                            <p>Status: ${buildStatus}</p>
                            <p>Started By: ${buildUser}</p>
                            <p>Build URL: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                        """,
                        to: 'ravireddy6198@gmail.com',
                        from: 'ravireddy6198@gmail.com',
                        mimeType: 'text/html',
                        attachmentsPattern: 'gosec-report.json,govulncheck-report.txt,checkov-report.json,trivy-license-report.txt,trivy-fs-report.txt,trivy-image-shippingservice.json,trivy-image-shippingservice.txt,sbom.json'
                    )
                }
            }
            cleanWs()
        }
    }
}