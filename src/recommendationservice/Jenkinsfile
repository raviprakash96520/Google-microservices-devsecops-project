pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        SCANNER_HOME    = tool 'sonar-scanner'
        DOCKER_NAME     = 'ravi6198/recommendationservice'
        IMAGE_NAME      = 'recommendationservice'
        SERVICE_DIR     = 'src/recommendationservice'
        SONAR_TOKEN_ID  = 'sonar-token'
        DOCKER_CREDS_ID = 'docker-cred'
        EMAIL_ID        = 'ravireddy6198@gmail.com'
    }

    stages {
        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/raviprakash96520/Google-microservices-devsecops-project.git'
            }
        }

        stage("Gitleaks Secret Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    echo "Running secret scan..."
                    gitleaks detect --source=. --verbose || true
                    '''
                }
            }
        }

        stage("License Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    echo "Running license scan..."
                    trivy fs . --scanners license --severity HIGH,CRITICAL > trivy-license-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-license-report.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Bandit Security Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    python3 -m pip install --user bandit
                    bandit -r . -f json -o bandit-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/bandit-report.json", allowEmptyArchive: true
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                          -Dsonar.projectKey=recommendationservice \
                          -Dsonar.projectName=recommendationservice \
                          -Dsonar.sources=. \
                          -Dsonar.language=py
                        '''
                    }
                }
            }
        }

        stage("Quality Gate") {
            steps {
                script {
                    timeout(time: 3, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true, credentialsId: "${SONAR_TOKEN_ID}"
                    }
                }
            }
        }

        stage("Install Dependencies") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh 'python3 -m pip install --user -r requirements.txt || true'
                }
            }
        }

        stage("Unit Test & Coverage") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    python3 -m pip install --user pytest pytest-cov
                    pytest --cov=. --cov-report=xml || true
                    '''
                }
            }
        }

        stage("Safety Dependency Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    python3 -m pip install --user safety
                    safety check --full-report --output json > safety-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/safety-report.json", allowEmptyArchive: true
                }
            }
        }

        stage("Checkov IaC Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    python3 -m pip install --user checkov
                    checkov -d . --output json > checkov-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/checkov-report.json", allowEmptyArchive: true
                }
            }
        }

        stage("Trivy File Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh '''
                    trivy fs . --severity CRITICAL,HIGH --scanners vuln,misconfig,secret --exit-code 1 > trivy-fs-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-fs-report.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    script {
                        env.FINAL_TAG = "${DOCKER_NAME}:${BUILD_NUMBER}"
                        sh """
                        echo "Removing old image if exists..."
                        docker rmi -f ${IMAGE_NAME} ${env.FINAL_TAG} || true

                        echo "Building Docker Image..."
                        docker build -t ${IMAGE_NAME} .

                        echo "Tagging image..."
                        docker tag ${IMAGE_NAME} ${env.FINAL_TAG}
                        """
                    }
                }
            }
        }

        stage("Generate SBOM Manifest") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh 'trivy image --format cyclonedx --output sbom.json ${FINAL_TAG}'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/sbom.json", allowEmptyArchive: true
                }
            }
        }

        stage("Trivy Container Image Scan") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh """
                    trivy image -f json -o trivy-image-recommendationservice.json ${env.FINAL_TAG}
                    trivy image -f table -o trivy-image-recommendationservice.txt ${env.FINAL_TAG}
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-image-recommendationservice.json", allowEmptyArchive: true
                    archiveArtifacts artifacts: "${env.SERVICE_DIR}/trivy-image-recommendationservice.txt", allowEmptyArchive: true
                }
            }
        }

        stage("Push Image To DockerHub") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    withCredentials([
                        string(credentialsId: "${DOCKER_CREDS_ID}", variable: 'dockerpwd')
                    ]) {
                        sh '''
                        echo "Docker login..."
                        echo "$dockerpwd" | docker login -u ravi6198 --password-stdin

                        echo "Pushing version image..."
                        docker push ${FINAL_TAG}

                        echo "Creating latest tag..."
                        docker tag ${IMAGE_NAME} ${DOCKER_NAME}:latest

                        echo "Pushing latest image..."
                        docker push ${DOCKER_NAME}:latest
                        '''
                    }
                }
            }
        }

        stage("Cosign Image Signing") {
            steps {
                dir("${env.SERVICE_DIR}") {
                    echo "Cosign signing skipped - key not configured"
                    // Enable after adding Jenkins cosign key credential
                }
            }
        }
    }

    post {
        always {
            dir("${env.SERVICE_DIR}") {
                script {
                    def buildStatus = currentBuild.currentResult
                    def buildUser = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')[0]?.userId ?: 'Jenkins User'

                    emailext (
                        subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
                            <h3>Recommendationservice DevSecOps Pipeline Report</h3>
                            <p>Project: ${env.JOB_NAME}</p>
                            <p>Service: ${env.SERVICE_DIR}</p>
                            <p>Build Number: ${env.BUILD_NUMBER}</p>
                            <p>Status: ${buildStatus}</p>
                            <p>Started By: ${buildUser}</p>
                            <p>Build URL: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                        """,
                        to: "${EMAIL_ID}",
                        from: "${EMAIL_ID}",
                        mimeType: "text/html",
                        attachmentsPattern: 'bandit-report.json,safety-report.json,checkov-report.json,trivy-license-report.txt,trivy-fs-report.txt,trivy-image-recommendationservice.json,trivy-image-recommendationservice.txt,sbom.json'
                    )
                }
            }
            cleanWs()
        }
    }
}